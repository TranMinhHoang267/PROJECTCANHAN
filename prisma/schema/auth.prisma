model User {
  id             String    @id @default(uuid()) @map("id")
  email          String    @unique @map("email")
  password       String    @map("password")
  full_name      String?   @map("full_name")
  role           String    @default("candidate") @map("role")
  avatar_url     String?   @map("avatar_url")
  phone          String    @unique @map("phone")
  refresh_token  String?   @db.Text @map("refresh_token")
  is_active      Boolean   @default(true) @map("is_active")
  created_at     DateTime  @default(now()) @map("created_at")
  updated_at     DateTime  @updatedAt @map("updated_at")

  // Relations - 1:1
  candidateProfile Candidate_profile?  @relation("UserToCandidateProfile")
  companyProfile   Company?           @relation("UserToCompany")
  // Relations - 1:N
  resumes          Resume[]           @relation("UserToResume")
  applications     Application[]      @relation("UserToApplication")
  bookmarks        Bookmark[]         @relation("UserToBookmark")

  @@map("users")
}
